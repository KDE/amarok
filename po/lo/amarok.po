#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:13
#, kde-format
msgid "Whether to display a second, left time label."
msgstr "ຈະສະແດງປ້າຍບອກເວລາອັນທີສອງ ດ້ານຊ້າຍ ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:14
#, kde-format
msgid ""
"Set this to display a second time label to the left of the seek slider in "
"the player window."
msgstr "ຕັ້ງຄ່ານີ້ເພື່ອສະແດງປ້າຍບອກເວລາອັນທີສອງ ຢູ່ທາງຊ້າຍຂອງແຖບເລື່ອນການຫຼິ້ນໃນໜ້າຕ່າງເຄື່ອງຫຼິ້ນ."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:18
#, kde-format
msgid "Whether to display remaining track time in the left time label."
msgstr "ຈະສະແດງເວລາທີ່ເຫຼືອຂອງແທຣັກໃນປ້າຍບອກເວລາດ້ານຊ້າຍ ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:19
#, kde-format
msgid ""
"Set this to display remaining track time instead of past track time in the "
"player window."
msgstr "ຕັ້ງຄ່ານີ້ເພື່ອສະແດງເວລາທີ່ເຫຼືອຂອງແທຣັກ ແທນທີ່ຈະເປັນເວລາທີ່ຫຼິ້ນໄປແລ້ວໃນໜ້າຕ່າງເຄື່ອງຫຼິ້ນ."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:23
#, kde-format
msgid "Which tracks or albums to favor in Random Mode"
msgstr "ແທຣັກ ຫຼື ອັນບັ້ມໃດທີ່ຕ້ອງການເນັ້ນໃນໂໝດສຸ່ມ"

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:24
#, kde-format
msgid ""
"Tracks or albums with the chosen property will be more likely to be chosen "
"in Random Mode."
msgstr "ແທຣັກ ຫຼື ອັນບັ້ມທີ່ມີຄຸນສົມບັດທີ່ເລືອກໄວ້ ຈະມີໂອກາດຖືກເລືອກຫຼາຍຂຶ້ນໃນໂໝດສຸ່ມ."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:34
#, kde-format
msgid "How to progress through tracks in the playlist"
msgstr "ວິທີການຫຼິ້ນຕໍ່ເນື່ອງຂອງແທຣັກໃນລາຍການຫຼິ້ນ"

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:35
#, kde-format
msgid "Determines how amarok will progress through the tracks in the playlist"
msgstr "ກຳນົດວິທີທີ່ Amarok ຈະຫຼິ້ນແທຣັກຕໍ່ໄປໃນລາຍການຫຼິ້ນ"

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:48
#, kde-format
msgid "The status of dynamic mode."
msgstr "ສະຖານະຂອງໂໝດໄດນາມິກ."

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:49
#, kde-format
msgid ""
"If set, dynamic mode will be on, and tracks will be added according to the "
"dynamic playlist specified."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, ໂໝດໄດນາມິກຈະເປີດ ແລະ ແທຣັກຈະຖືກເພີ່ມເຂົ້າມາຕາມລາຍການຫຼິ້ນໄດນາມິກທີ່ກຳນົດໄວ້."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:53
#, kde-format
msgid "Duplicate tracks in dynamic mode."
msgstr "ແທຣັກຊ້ຳກັນໃນໂໝດໄດນາມິກ."

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:54
#, kde-format
msgid ""
"If set, tracks added in the dynamic mode are allowed to have duplicates."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, ແທຣັກທີ່ເພີ່ມໃນໂໝດໄດນາມິກຈະໄດ້ຮັບອະນຸຍາດໃຫ້ມີລາຍການຊ້ຳກັນໄດ້."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:58
#, kde-format
msgid "Previous tracks count."
msgstr "ຈຳນວນແທຣັກກ່ອນໜ້າ."

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:59
#, kde-format
msgid "Number of tracks to leave in the playlist before the active track."
msgstr "ຈຳນວນແທຣັກທີ່ຈະປະໄວ້ໃນລາຍການຫຼິ້ນ ກ່ອນໜ້າແທຣັກທີ່ກຳລັງຫຼິ້ນຢູ່."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:63
#, kde-format
msgid "Upcoming tracks count."
msgstr "ຈຳນວນແທຣັກທີ່ຈະມາເຖິງ."

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:64
#, kde-format
msgid "Number of tracks to load into the playlist after the active track."
msgstr "ຈຳນວນແທຣັກທີ່ຈະໂຫຼດເຂົ້າໃນລາຍການຫຼິ້ນ ຕໍ່ຈາກແທຣັກທີ່ກຳລັງຫຼິ້ນຢູ່."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:68
#, kde-format
msgid "Whether to show icon in system tray"
msgstr "ຈະສະແດງໄອຄອນໃນຖາດລະບົບ ຫຼື ບໍ່"

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:69
#, kde-format
msgid "Enable/Disable tray icon for Amarok."
msgstr "ເປີດ/ປິດ ໄອຄອນຖາດລະບົບສຳລັບ Amarok."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:73
#, kde-format
msgid "Whether to hide the context view."
msgstr "ຈະເຊື່ອງມຸມມອງ Context ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:74
#, kde-format
msgid "Enable/Disable context view in Amarok."
msgstr "ເປີດ/ປິດ ມຸມມອງ Context ໃນ Amarok."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:78
#, kde-format
msgid "Number of undo levels in playlist"
msgstr "ຈຳນວນລະດັບການກັບຄືນ (Undo) ໃນລາຍການຫຼິ້ນ"

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:79
#, kde-format
msgid "The number of undo levels in the playlist."
msgstr "ຈຳນວນຂັ້ນຕອນທີ່ສາມາດຍົກເລີກການກະທຳໄດ້ໃນລາຍການຫຼິ້ນ."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:83
#, kde-format
msgid "Whether playlists store relative path"
msgstr "ຈະໃຫ້ລາຍການຫຼິ້ນບັນທຶກເສັ້ນທາງແບບ Relative ຫຼື ບໍ່"

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:84
#, kde-format
msgid ""
"If set, Amarok's manually saved playlists will contain a relative path to "
"each track, not an absolute path."
msgstr ""
"ຖ້າຕັ້ງຄ່າໄວ້, ລາຍການຫຼິ້ນທີ່ບັນທຶກດ້ວຍຕົນເອງຂອງ Amarok ຈະໃຊ້ເສັ້ນທາງແບບ Relative "
"ໄປຫາແຕ່ລະແທຣັກ, ບໍ່ແມ່ນເສັ້ນທາງແບບເຕັມ (Absolute)."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:88
#, kde-format
msgid "Filename of the external web browser to be invoked by Amarok."
msgstr "ຊື່ໄຟລ໌ຂອງເວັບບຣາວເຊີພາຍນອກທີ່ຈະຖືກຮຽກໃຊ້ໂດຍ Amarok."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:92
#, kde-format
msgid "Whether to automatically attempt to fetch cover art as needed"
msgstr "ຈະພະຍາຍາມດຶງເອົາຮູບໜ້າປົກໂດຍອັດຕະໂນມັດຕາມຄວາມຕ້ອງການ ຫຼື ບໍ່"

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:96
#, kde-format
msgid "Whether to show background images in the browser pane"
msgstr "ຈະສະແດງຮູບພື້ນຫຼັງໃນແຖບບຣາວເຊີ ຫຼື ບໍ່"

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:100
#, kde-format
msgid ""
"Automatically scroll the playlist to make the currently playing track visible"
msgstr "ເລື່ອນລາຍການຫຼິ້ນໂດຍອັດຕະໂນມັດ ເພື່ອໃຫ້ເຫັນແທຣັກທີ່ກຳລັງຫຼິ້ນຢູ່"

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:104
#, kde-format
msgid "Show Album art in the Collection Browser"
msgstr "ສະແດງຮູບອັນບັ້ມໃນບຣາວເຊີຄັງເພງ"

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:108
#, kde-format
msgid "Show the Context View"
msgstr "ສະແດງມຸມມອງ Context"

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:112
#, kde-format
msgid "Play the first run jingle"
msgstr "ຫຼິ້ນສຽງຕ້ອນຮັບເມື່ອເປີດໂປຣແກຣມຄັ້ງທຳອິດ"

#. i18n: ectx: label, entry, group (General Options)
#. i18n: ectx: property (text), widget (QCheckBox, kcfg_AnimateAppletCollapse)
#: amarokconfig.kcfg:116 configdialog/dialogs/GeneralConfig.ui:61
#, kde-format
msgid "Enable context applets collapse animations"
msgstr "ເປີດໃຊ້ພາບເຄື່ອນໄຫວເມື່ອຫຍໍ້ແອັບເພຼັດ Context"

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:117
#, kde-format
msgid "If set, context applets will collapse using animations."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, ແອັບເພຼັດ Context ຈະຫຍໍ້ລົງໂດຍໃຊ້ພາບເຄື່ອນໄຫວ."

#. i18n: ectx: label, entry, group (General Options)
#: amarokconfig.kcfg:121
#, kde-format
msgid ""
"Show track's artist in Collection Browser if different from album artist"
msgstr "ສະແດງຊື່ສິນລະປິນຂອງແທຣັກໃນບຣາວເຊີຄັງເພງ ຖ້າຫາກແຕກຕ່າງຈາກສິນລະປິນຂອງອັນບັ້ມ"

#. i18n: ectx: whatsthis, entry, group (General Options)
#: amarokconfig.kcfg:122
#, kde-format
msgid ""
"Explicitly show artist in Collection Browser for Various Artists albums and "
"tracks where artist differs from album artist."
msgstr ""
"ສະແດງຊື່ສິນລະປິນຢ່າງຊັດເຈນໃນບຣາວເຊີຄັງເພງ ສຳລັບອັນບັ້ມລວມສິນລະປິນ (Various Artists) ແລະ "
"ແທຣັກທີ່ສິນລະປິນແຕກຕ່າງຈາກສິນລະປິນຂອງອັນບັ້ມ."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:129
#, kde-format
msgid "Whether organize files will overwrite existing files."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະຂຽນທັບໄຟລ໌ທີ່ມີຢູ່ແລ້ວ ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:130
#, kde-format
msgid "If set, Organize files will overwrite any existing destination."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, ການຈັດລະບຽບໄຟລ໌ຈະຂຽນທັບປາຍທາງທີ່ມີຢູ່ແລ້ວ."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:134
#, kde-format
msgid "Whether organize files will move The in artist names to the end."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະຍ້າຍຄຳວ່າ 'The' ໃນຊື່ສິນລະປິນໄປໄວ້ທາງຫຼັງ ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:135
#, kde-format
msgid ""
"If set, Organize files will move The in artist names to the end as in "
"\"Beatles, The\"."
msgstr ""
"ຖ້າຕັ້ງຄ່າໄວ້, ການຈັດລະບຽບໄຟລ໌ຈະຍ້າຍຄຳວ່າ 'The' ໃນຊື່ສິນລະປິນໄປໄວ້ທາງຫຼັງ ເຊັ່ນ: \"Beatles, The"
"\"."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:139
#, kde-format
msgid ""
"Whether organize files will replace spaces in filenames with underscores."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະປ່ຽນຍະຫວ່າງໃນຊື່ໄຟລ໌ເປັນຂີດກ້ອງ (_) ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:140
#, kde-format
msgid ""
"If set, Organize files will replace spaces in filenames with underscores."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, ການຈັດລະບຽບໄຟລ໌ຈະປ່ຽນຍະຫວ່າງໃນຊື່ໄຟລ໌ເປັນຂີດກ້ອງ (_)."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:144
#, kde-format
msgid "Whether organize files will use cover art as folder icons."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະໃຊ້ຮູບໜ້າປົກເປັນໄອຄອນໂຟນເດີ ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:145
#, kde-format
msgid "If set, Organize files will use cover art as folder icons."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, ການຈັດລະບຽບໄຟລ໌ຈະໃຊ້ຮູບໜ້າປົກເປັນໄອຄອນໂຟນເດີ."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:149
#, kde-format
msgid "Collection folder path destination for Organize files."
msgstr "ເສັ້ນທາງໂຟນເດີຄັງເພງປາຍທາງສຳລັບການຈັດລະບຽບໄຟລ໌."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:150
#, kde-format
msgid "The path of the collection folder destination for Organize files."
msgstr "ເສັ້ນທາງຂອງໂຟນເດີຄັງເພງປາຍທາງສຳລັບການຈັດລະບຽບໄຟລ໌."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:154
#, kde-format
msgid ""
"Whether organize files will rename files in a manner compatible with vfat "
"filesystems."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະປ່ຽນຊື່ໄຟລ໌ໃນຮູບແບບທີ່ເຂົ້າກັນໄດ້ກັບລະບົບໄຟລ໌ vfat ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:155
#, kde-format
msgid ""
"If set, Organize files will replace characters that are not compatible with "
"vfat filesystems (such as ':', '*' and '?')."
msgstr ""
"ຖ້າຕັ້ງຄ່າໄວ້, ການຈັດລະບຽບໄຟລ໌ຈະປ່ຽນຕົວອັກສອນທີ່ບໍ່ເຂົ້າກັນກັບລະບົບໄຟລ໌ vfat (ເຊັ່ນ: ':', '*' ແລະ "
"'?')."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:159
#, kde-format
msgid ""
"Whether organize files will rename files such that they only contain 7-bit "
"ASCII characters."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະປ່ຽນຊື່ໄຟລ໌ໃຫ້ມີພຽງແຕ່ຕົວອັກສອນ 7-bit ASCII ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:160
#, kde-format
msgid ""
"If set, Organize files will replace characters that are not compatible with "
"the 7-bit ASCII character set."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, ການຈັດລະບຽບໄຟລ໌ຈະປ່ຽນຕົວອັກສອນທີ່ບໍ່ເຂົ້າກັນກັບຊຸດຕົວອັກສອນ 7-bit ASCII."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:164
#, kde-format
msgid "Whether organize files will use a custom file naming scheme."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະໃຊ້ຮູບແບບການຕັ້ງຊື່ໄຟລ໌ແບບກຳນົດເອງ ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:165
#, kde-format
msgid ""
"If set, Organize files will rename files according to a custom format string."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, ການຈັດລະບຽບໄຟລ໌ຈະປ່ຽນຊື່ໄຟລ໌ຕາມຮູບແບບສະຕຣິງທີ່ກຳນົດເອງ."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:169
#, kde-format
msgid "Format string for Organize files, if a custom naming scheme is used."
msgstr "ຮູບແບບສະຕຣິງສຳລັບການຈັດລະບຽບໄຟລ໌, ຖ້າຫາກໃຊ້ຮູບແບບການຕັ້ງຊື່ແບບກຳນົດເອງ."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:170
#, kde-format
msgid ""
"If the custom filename scheme is enabled, then Organize files will rename "
"files according to this format string."
msgstr "ຖ້າເປີດໃຊ້ຮູບແບບຊື່ໄຟລ໌ແບບກຳນົດເອງ, ການຈັດລະບຽບໄຟລ໌ຈະປ່ຽນຊື່ໄຟລ໌ຕາມຮູບແບບສະຕຣິງນີ້."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:174
#, kde-format
msgid "Regular expression that is to be replaced."
msgstr "Regular expression ທີ່ຈະຖືກແທນທີ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:175
#, kde-format
msgid ""
"Organize files will replace substrings matching this regular expression."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະແທນທີ່ຂໍ້ຄວາມທີ່ກົງກັບ regular expression ນີ້."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:179
#, kde-format
msgid "Replacing string."
msgstr "ສະຕຣິງທີ່ຈະນຳມາແທນທີ່."

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:180
#, kde-format
msgid "Organize files will replace matching substrings with this string."
msgstr "ການຈັດລະບຽບໄຟລ໌ຈະແທນທີ່ຂໍ້ຄວາມທີ່ກົງກັນ ດ້ວຍສະຕຣິງນີ້."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:184
#, kde-format
msgid "Basic or Advanced Mode"
msgstr "ໂໝດພື້ນຖານ ຫຼື ຂັ້ນສູງ"

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:185
#, kde-format
msgid ""
"In basic mode graphical drag/droppable tokens are used to create a filename "
"scheme, in advanced mode the images are replaced with text."
msgstr ""
"ໃນໂໝດພື້ນຖານ ຈະໃຊ້ໂທເຄັນກຣາບຟິກທີ່ລາກວາງໄດ້ ເພື່ອສ້າງຮູບແບບຊື່ໄຟລ໌, ໃນໂໝດຂັ້ນສູງ "
"ຮູບພາບຈະຖືກແທນທີ່ດ້ວຍຂໍ້ຄວາມ."

#. i18n: ectx: label, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:189
#, kde-format
msgid "Format Presets"
msgstr "ຮູບແບບທີ່ຕັ້ງໄວ້ລ່ວງໜ້າ"

#. i18n: ectx: whatsthis, entry, group (OrganizeCollectionDialog)
#: amarokconfig.kcfg:190
#, kde-format
msgid "A list of preset formats (token schemas)."
msgstr "ລາຍການຂອງຮູບແບບທີ່ຕັ້ງໄວ້ລ່ວງໜ້າ (ໂຄງສ້າງໂທເຄັນ)."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:197
#, kde-format
msgid "Master volume"
msgstr "ລະດັບສຽງຫຼັກ"

#. i18n: ectx: whatsthis, entry, group (Playback)
#: amarokconfig.kcfg:198
#, kde-format
msgid "The Amarok master volume, a value between 0 and 100."
msgstr "ລະດັບສຽງຫຼັກຂອງ Amarok, ຄ່າລະຫວ່າງ 0 ຫາ 100."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:204
#, kde-format
msgid "Mute state"
msgstr "ສະຖານະປິດສຽງ"

#. i18n: ectx: whatsthis, entry, group (Playback)
#: amarokconfig.kcfg:205
#, kde-format
msgid "Mute/Unmute sound."
msgstr "ປິດສຽງ/ເປີດສຽງ."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:209
#, kde-format
msgid "Whether to fade out tracks when pressing stop."
msgstr "ຈະຫຼຸດສຽງແທຣັກລົງຄ່ອຍໆ (Fade out) ເມື່ອກົດຢຸດ ຫຼື ບໍ່."

#. i18n: ectx: whatsthis, entry, group (Playback)
#: amarokconfig.kcfg:210 amarokconfig.kcfg:215
#, kde-format
msgid "Enable/Disable fadeout."
msgstr "ເປີດ/ປິດ ການຫຼຸດສຽງລົງຄ່ອຍໆ (Fadeout)."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:214
#, kde-format
msgid "Whether to fade out tracks when pressing pause."
msgstr "ຈະຫຼຸດສຽງແທຣັກລົງຄ່ອຍໆ ເມື່ອກົດຢຸດຊົ່ວຄາວ ຫຼື ບໍ່."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:219
#, kde-format
msgid "Length of fadeout, in milliseconds"
msgstr "ໄລຍະເວລາຂອງການ Fadeout, ເປັນມິນລິວິນາທີ"

#. i18n: ectx: whatsthis, entry, group (Playback)
#: amarokconfig.kcfg:220
#, kde-format
msgid "The length of the fadeout in milliseconds."
msgstr "ໄລຍະເວລາຂອງການ Fadeout ເປັນມິນລິວິນາທີ."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:225
#, kde-format
msgid "Equalizer mode - 0 = off, 1 to n = preset no"
msgstr "ໂໝດ Equalizer - 0 = ປິດ, 1 ຫາ n = ເລກທີ່ Preset"

#. i18n: ectx: whatsthis, entry, group (Playback)
#: amarokconfig.kcfg:226
#, kde-format
msgid "When enabled, an equalizer plugin filters the audio stream."
msgstr "ເມື່ອເປີດໃຊ້, ປັ໊ກອິນ Equalizer ຈະກອງສັນຍານສຽງ."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:230
#, kde-format
msgid "11 Equalizer gains including pre-amp, range -100..100, 0 is normal."
msgstr "11 ຄ່າ Gain ຂອງ Equalizer ລວມທັງ pre-amp, ຊ່ວງ -100..100, 0 ແມ່ນປົກກະຕິ."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:234
#, kde-format
msgid "List with user equalizer preset names"
msgstr "ລາຍການຊື່ Preset Equalizer ຂອງຜູ້ໃຊ້"

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:237
#, kde-format
msgid "List with user presets values"
msgstr "ລາຍການຄ່າ Preset ຂອງຜູ້ໃຊ້"

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:241
#, kde-format
msgid "The mode for adjusting playback volume."
msgstr "ໂໝດສຳລັບການປັບລະດັບສຽງການຫຼິ້ນ."

#. i18n: ectx: whatsthis, entry, group (Playback)
#: amarokconfig.kcfg:242
#, kde-format
msgid ""
"Whether to adjust the volume of tracks to make them sound the same volume, "
"and if so whether to make the adjustments per-track or per-album."
msgstr "ຈະປັບລະດັບສຽງຂອງແທຣັກໃຫ້ມີຄວາມດັງເທົ່າກັນ ຫຼື ບໍ່, ແລະ ຖ້າເຮັດ ຈະປັບແບບຕໍ່ແທຣັກ ຫຼື ຕໍ່ອັນບັ້ມ."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:245
#, kde-format
msgid "Disable Replay Gain"
msgstr "ປິດໃຊ້ງານ Replay Gain"

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:248
#, kde-format
msgid "Make each track the same volume"
msgstr "ເຮັດໃຫ້ແຕ່ລະແທຣັກມີລະດັບສຽງເທົ່າກັນ"

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:251
#, kde-format
msgid "Make each album the same volume"
msgstr "ເຮັດໃຫ້ແຕ່ລະອັນບັ້ມມີລະດັບສຽງເທົ່າກັນ"

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:257
#, kde-format
msgid "The length of a short seek, in seconds."
msgstr "ໄລຍະເວລາຂອງການເລື່ອນສັ້ນໆ (Short seek), ເປັນວິນາທີ."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:262
#, kde-format
msgid "The length of a medium seek, in seconds."
msgstr "ໄລຍະເວລາຂອງການເລື່ອນປານກາງ, ເປັນວິນາທີ."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:267
#, kde-format
msgid "The length of a long seek, in seconds."
msgstr "ໄລຍະເວລາຂອງການເລື່ອນຍາວ, ເປັນວິນາທີ."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:272
#, kde-format
msgid "Whether Amarok should pause the currently playing track on suspend."
msgstr "Amarok ຄວນຢຸດຫຼິ້ນແທຣັກປັດຈຸບັນຊົ່ວຄາວ ເມື່ອມີການພັກເຄື່ອງ (Suspend) ຫຼື ບໍ່."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:276
#, kde-format
msgid ""
"Whether Amarok should prevent the system from sleeping if it is playing a "
"track."
msgstr "Amarok ຄວນປ້ອງກັນບໍ່ໃຫ້ລະບົບເຂົ້າສູ່ໂໝດນອນຫຼັບ (Sleep) ຖ້າມັນກຳລັງຫຼິ້ນແທຣັກຢູ່ ຫຼື ບໍ່."

#. i18n: ectx: label, entry, group (Playback)
#: amarokconfig.kcfg:280
#, kde-format
msgid ""
"Whether Amarok should start playing if a track is added to playlist (and "
"nothing else is playing)."
msgstr "Amarok ຄວນເລີ່ມຫຼິ້ນ ຫຼື ບໍ່ ຖ້າມີແທຣັກຖືກເພີ່ມເຂົ້າໃນລາຍການຫຼິ້ນ (ແລະ ບໍ່ມີຫຍັງຫຼິ້ນຢູ່)."

#. i18n: ectx: label, entry, group (Cover Manager)
#: amarokconfig.kcfg:287
#, kde-format
msgid "Amazon locale for cover retrieval"
msgstr "ພາກພື້ນ Amazon ສຳລັບການດຶງຮູບໜ້າປົກ"

#. i18n: ectx: whatsthis, entry, group (Cover Manager)
#: amarokconfig.kcfg:288
#, kde-format
msgid "Determines which Amazon server cover images should be retrieved from."
msgstr "ກຳນົດວ່າຈະດຶງຮູບໜ້າປົກມາຈາກເຊີບເວີ Amazon ໃດ."

#. i18n: ectx: label, entry, group (Wikipedia)
#: amarokconfig.kcfg:295
#, kde-format
msgid "Wikipedia locale for information retrieval"
msgstr "ພາກພື້ນ Wikipedia ສຳລັບການດຶງຂໍ້ມູນ"

#. i18n: ectx: whatsthis, entry, group (Wikipedia)
#: amarokconfig.kcfg:296
#, kde-format
msgid ""
"Determines in which language the information is retrieved from Wikipedia."
msgstr "ກຳນົດພາສາທີ່ຈະໃຊ້ດຶງຂໍ້ມູນມາຈາກ Wikipedia."

#. i18n: ectx: label, entry, group (KNotify)
#: amarokconfig.kcfg:303
#, kde-format
msgid "Use KNotify support"
msgstr "ໃຊ້ການຮອງຮັບ KNotify"

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:310
#, kde-format
msgid "Use On-Screen Display"
msgstr "ໃຊ້ການສະແດງຜົນເທິງໜ້າຈໍ (OSD)"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:311
#, kde-format
msgid "Enable/Disable the On-Screen Display."
msgstr "ເປີດ/ປິດ ການສະແດງຜົນເທິງໜ້າຈໍ (OSD)."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:315 configdialog/dialogs/NotificationsConfig.cpp:49
#, kde-format
msgid "Use Growl for notifications"
msgstr "ໃຊ້ Growl ສຳລັບການແຈ້ງເຕືອນ"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:316
#, kde-format
msgid "Enable/Disable use of Growl for notifications."
msgstr "ເປີດ/ປິດ ການໃຊ້ Growl ສຳລັບການແຈ້ງເຕືອນ."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:320
#, kde-format
msgid "Translucency Toggle"
msgstr "ສະຫຼັບຄວາມໂປ່ງແສງ"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:321
#, kde-format
msgid "Make the background of the OSD translucent."
msgstr "ເຮັດໃຫ້ພື້ນຫຼັງຂອງ OSD ໂປ່ງແສງ."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:325
#, kde-format
msgid "Whether to use custom colors for the OSD"
msgstr "ຈະໃຊ້ສີທີ່ກຳນົດເອງສຳລັບ OSD ຫຼື ບໍ່"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:326
#, kde-format
msgid "You can use custom colors for the OSD if you set this true."
msgstr "ທ່ານສາມາດໃຊ້ສີທີ່ກຳນົດເອງສຳລັບ OSD ໄດ້ ຖ້າທ່ານເປີດຄ່ານີ້."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:330
#, kde-format
msgid "Font color for OSD"
msgstr "ສີຕົວອັກສອນສຳລັບ OSD"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:331
#, kde-format
msgid ""
"The color of the OSD text. The color is specified in RGB, a comma-separated "
"list containing three integers between 0 and 255."
msgstr ""
"ສີຂອງຂໍ້ຄວາມ OSD. ສີຖືກລະບຸເປັນ RGB, ເຊິ່ງເປັນລາຍການທີ່ຂັ້ນດ້ວຍຈຸດ ປະກອບດ້ວຍຈຳນວນເຕັມສາມຕົວ "
"ລະຫວ່າງ 0 ຫາ 255."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:335
#, kde-format
msgid "Font scaling for OSD"
msgstr "ການຂະຫຍາຍຂະໜາດຕົວອັກສອນສຳລັບ OSD"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:336
#, kde-format
msgid ""
"The scaling multiplier for the OSD font, in percent-of-normal. 100 is &#8220;"
"normal size&#8221;."
msgstr ""
"ຕົວຄູນຂະຫຍາຍສຳລັບຕົວອັກສອນ OSD, ເປັນເປີເຊັນຂອງຂະໜາດປົກກະຕິ. 100 ແມ່ນ &#8220;"
"ຂະໜາດປົກກະຕິ&#8221;."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:342
#, kde-format
msgid "How many milliseconds the text should be displayed for"
msgstr "ເວລາທີ່ຈະສະແດງຂໍ້ຄວາມເປັນມິນລິວິນາທີ"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:343
#, kde-format
msgid ""
"The time in milliseconds to show the OSD. A value of 0 means never hide. The "
"default value is 5000 ms."
msgstr "ເວລາເປັນມິນລິວິນາທີເພື່ອສະແດງ OSD. ຄ່າ 0 ໝາຍເຖິງບໍ່ເຊື່ອງຈັກເທື່ອ. ຄ່າເລີ່ມຕົ້ນແມ່ນ 5000 ms."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:348
#, kde-format
msgid "Y position offset"
msgstr "ໄລຍະຫ່າງຕຳແໜ່ງ Y"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:349
#, kde-format
msgid ""
"The Y position of the OSD relative to the chosen screen and OSD alignment. "
"If Top alignment is chosen the Y offset is the space between the upper part "
"of the OSD and the top of the screen. If Bottom alignment is chosen the Y "
"offset is the space between the bottom part of the OSD and the bottom of the "
"screen."
msgstr ""
"ຕຳແໜ່ງ Y ຂອງ OSD ທຽບກັບໜ້າຈໍທີ່ເລືອກ ແລະ ການຈັດຕຳແໜ່ງ OSD. ຖ້າເລືອກຈັດຕຳແໜ່ງດ້ານເທິງ, Y "
"offset ແມ່ນຊ່ອງວ່າງລະຫວ່າງສ່ວນເທິງຂອງ OSD ແລະ ຂອບເທິງຂອງໜ້າຈໍ. ຖ້າເລືອກຈັດຕຳແໜ່ງດ້ານລຸ່ມ, Y "
"offset ແມ່ນຊ່ອງວ່າງລະຫວ່າງສ່ວນລຸ່ມຂອງ OSD ແລະ ຂອບລຸ່ມຂອງໜ້າຈໍ."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:355
#, kde-format
msgid "OSD screen"
msgstr "ໜ້າຈໍ OSD"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:356
#, kde-format
msgid ""
"The screen that should display the OSD. For single-headed environments this "
"setting should be 0."
msgstr "ໜ້າຈໍທີ່ຄວນສະແດງ OSD. ສຳລັບສະພາບແວດລ້ອມໜ້າຈໍດຽວ ການຕັ້ງຄ່ານີ້ຄວນເປັນ 0."

#. i18n: ectx: label, entry, group (OSD)
#: amarokconfig.kcfg:360
#, kde-format
msgid "Align OSD to"
msgstr "ຈັດຕຳແໜ່ງ OSD ໄປທາງ"

#. i18n: ectx: whatsthis, entry, group (OSD)
#: amarokconfig.kcfg:361
#, kde-format
msgid ""
"The relative position of the OSD. Possible choices are Left, Middle, Right "
"and Center."
msgstr "ຕຳແໜ່ງສຳພັດຂອງ OSD. ທາງເລືອກທີ່ເປັນໄປໄດ້ແມ່ນ ຊ້າຍ, ກາງ, ຂວາ ແລະ ຈຸດສູນກາງ."

#. i18n: ectx: label, entry, group (OSD)
#. i18n: ectx: property (text), widget (QCheckBox, kcfg_OsdHideOnFullscreen)
#: amarokconfig.kcfg:371 configdialog/dialogs/NotificationsConfig.ui:264
#, kde-format
msgid "Don't show when a fullscreen application is active"
msgstr "ບໍ່ຕ້ອງສະແດງເມື່ອມີແອັບພລິເຄຊັນເຕັມໜ້າຈໍເຮັດວຽກຢູ່"

#. i18n: ectx: whatsthis, entry, group (OSD)
#. i18n: ectx: property (toolTip), widget (QCheckBox, kcfg_OsdHideOnFullscreen)
#: amarokconfig.kcfg:372 configdialog/dialogs/NotificationsConfig.ui:261
#, kde-format
msgid ""
"Do not show the On-Screen-Display if another application is focused and "
"running in fullscreen mode."
msgstr "ບໍ່ສະແດງ OSD ຖ້າຫາກມີແອັບພລິເຄຊັນອື່ນກຳລັງຖືກໃຊ້ງານ ແລະ ແລ່ນຢູ່ໃນໂໝດເຕັມໜ້າຈໍ."

#. i18n: ectx: label, entry, group (Session)
#: amarokconfig.kcfg:380
#, kde-format
msgid "Resume playback of last played track on startup"
msgstr "ສືບຕໍ່ການຫຼິ້ນແທຣັກຫຼ້າສຸດເມື່ອເລີ່ມຕົ້ນໂປຣແກຣມ"

#. i18n: ectx: whatsthis, entry, group (Session)
#: amarokconfig.kcfg:381
#, kde-format
msgid "If set, Amarok resumes playback of the last played track on startup."
msgstr "ຖ້າຕັ້ງຄ່າໄວ້, Amarok ຈະສືບຕໍ່ການຫຼິ້ນແທຣັກຫຼ້າສຸດເມື່ອເລີ່ມຕົ້ນໂປຣແກຣມ."

#. i18n: ectx: label, entry, group (Session)
#: amarokconfig.kcfg:385
#, kde-format
msgid "Track URL to resume upon startup"
msgstr "URL ຂອງແທຣັກທີ່ຈະສືບຕໍ່ເມື່ອເລີ່ມຕົ້ນ"

#. i18n: ectx: whatsthis, entry, group (Session)
#: amarokconfig.kcfg:386
#, kde-format
msgid "Internal: URL of the track to resume on startup."
msgstr "ພາຍໃນ: URL ຂອງແທຣັກທີ່ຈະສືບຕໍ່ເມື່ອເລີ່ມຕົ້ນ."

#. i18n: ectx: label, entry, group (Session)
#: amarokconfig.kcfg:389
#, kde-format
msgid "Internal: Resume playback in paused state"
msgstr "ພາຍໃນ: ສືບຕໍ່ການຫຼິ້ນໃນສະຖານະຢຸດຊົ່ວຄາວ"

#. i18n: ectx: label, entry, group (Session)
#: amarokconfig.kcfg:393
#, kde-format
msgid "Time to resume at, in milliseconds"
msgstr "ເວລາທີ່ຈະສືບຕໍ່, ເປັນມິນລິວິນາທີ"

#. i18n: ectx: whatsthis, entry, group (Session)
#: amarokconfig.kcfg:394
#, kde-format
msgid "Internal: Playback position in the track to resume on startup."
msgstr "ພາຍໃນ: ຕຳແໜ່ງການຫຼິ້ນໃນແທຣັກທີ່ຈະສືບຕໍ່ເມື່ອເລີ່ມຕົ້ນ."

#. i18n: ectx: label, entry, group (Session)
#: amarokconfig.kcfg:397
#, kde-format
msgid ""
"List of bools describing which browsers are visible, from top to bottom."
msgstr "ລາຍການຄ່າ Boolean ທີ່ບອກວ່າບຣາວເຊີໃດທີ່ສະແດງຢູ່, ຈາກເທິງລົງລຸ່ມ."

#. i18n: ectx: label, entry, group (Session)
#: amarokconfig.kcfg:400
#, kde-format
msgid "Track playing on last exit. Value is -1 if no track was playing."
msgstr "ແທຣັກທີ່ຫຼິ້ນຢູ່ຕອນອອກຄັ້ງສຸດທ້າຍ. ຄ່າແມ່ນ -1 ຖ້າບໍ່ມີແທຣັກໃດຫຼິ້ນຢູ່."

#. i18n: ectx: label, entry, group (Session)
#: amarokconfig.kcfg:404
#, kde-format
msgid "Number (from the top) of the last active browser."
msgstr "ໝາຍເລກ (ຈາກດ້ານເທິງ) ຂອງບຣາວເຊີທີ່ໃຊ້ງານຫຼ້າສຸດ."

#. i18n: ectx: label, entry, group (Collection)
#: amarokconfig.kcfg:410
#, kde-format
msgid "Whether Collections folders are scanned recursively"
msgstr "ໂຟນເດີຄັງເພງຖືກສະແກນແບບ Recursive (ລວມໂຟນເດີຍ່ອຍ) ຫຼື ບໍ່"

#. i18n: ectx: label, entry, group (Collection)
#: amarokconfig.kcfg:414
#, kde-format
msgid "Whether Collection folders are rescanned on change"
msgstr "ໂຟນເດີຄັງເພງຖືກສະແກນໃໝ່ເມື່ອມີການປ່ຽນແປງ ຫຼື ບໍ່"

#. i18n: ectx: label, entry, group (Collection)
#: amarokconfig.kcfg:418
#, kde-format
msgid "Whether meta data changes are written back"
msgstr "ການປ່ຽນແປງຂໍ້ມູນ Metadata ຖືກຂຽນກັບຄືນ ຫຼື ບໍ່"

#. i18n: ectx: label, entry, group (Collection)
#: amarokconfig.kcfg:422
#, kde-format
msgid "Whether changes to the track statistics are written back"
msgstr "ການປ່ຽນແປງສະຖິຕິຂອງແທຣັກຖືກຂຽນກັບຄືນ ຫຼື ບໍ່"

#. i18n: ectx: label, entry, group (Collection)
#: amarokconfig.kcfg:426
#, kde-format
msgid "Whether changes to the album cover are written back"
msgstr "ການປ່ຽນແປງຮູບໜ້າປົກອັນບັ້ມຖືກຂຽນກັບຄືນ ຫຼື ບໍ່"

#. i18n: ectx: label, entry, group (Collection)
#: amarokconfig.kcfg:430
#, kde-format
msgid "Maximum embedded cover dimensions"
